---
/**
 * SlideEngine: 마크다운 기반 프레젠테이션 엔진
 * - 방향키/스와이프 네비게이션, 풀스크린
 * - 판서 캔버스 (펜 색상 선택, 지우개 사이즈, 슬라이드별 저장)
 * - 스크래치 패드 (메인 콘텐츠 영역에서 floating)
 * - KaTeX 수식 렌더링
 *
 * 특수 슬라이드: <!-- blank -->, <!-- sim:파일명.html -->
 */
interface Props {
  title: string;
  slides: string[];
  pdfUrl?: string;
}

const { title, slides, pdfUrl } = Astro.props;
const base = import.meta.env.BASE_URL;

const penColors = [
  { color: '#ef4444', label: '빨강' },
  { color: '#1a1a1a', label: '검정' },
  { color: '#facc15', label: '노랑' },
  { color: '#22d3ee', label: '시안' },
  { color: '#4ade80', label: '초록' },
  { color: '#ffffff', label: '흰색' },
];

const eraserSizes = [
  { size: 15, label: 'S' },
  { size: 30, label: 'M' },
  { size: 60, label: 'L' },
];
---

<div id="slide-app" class="fixed inset-0 flex flex-col select-none" style="height: 100%; max-height: -webkit-fill-available;">
  <!-- Main content area (everything above toolbar) -->
  <div id="main-area" class="flex-1 relative overflow-hidden">
    <!-- Slides -->
    <div id="slides-container">
      {slides.map((html, i) => (
        <div
          class="slide absolute inset-0 flex items-center justify-center p-8"
          data-index={i}
          style={i === 0 ? '' : 'display:none'}
        >
          <div class="slide-content w-full max-w-4xl max-h-full overflow-auto" set:html={html} />
        </div>
      ))}
    </div>

    <!-- Floating feedback button (top-left) -->
    <button id="btn-feedback" class="absolute top-3 right-3 flex items-center justify-center w-9 h-9 rounded-full bg-white/80 backdrop-blur border border-[#8B0029]/20 text-[#8B0029]/40 hover:text-[#8B0029] hover:bg-white hover:border-[#8B0029]/40 shadow-sm transition-all" style="z-index: 8;" title="피드백 보내기">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    </button>

    <!-- Drawing canvas overlay (fills main area only) -->
    <canvas
      id="draw-canvas"
      class="absolute inset-0 w-full h-full"
      style="pointer-events: none; z-index: 10; touch-action: none;"
    ></canvas>

    <!-- Eraser cursor (positioned relative to main-area so it tracks correctly under iPad pinch-zoom) -->
    <div id="eraser-cursor" class="absolute rounded-full border-2 border-[#8B0029]/40 pointer-events-none hidden" style="z-index: 50;"></div>

    <!-- Scratch pad (floating in main area) -->
    <div id="scratch-pad" class="absolute inset-0 hidden" style="z-index: 20;">
      <div class="absolute inset-0 bg-black/40" id="scratch-backdrop"></div>
      <div class="absolute bg-white rounded-2xl shadow-2xl border border-[#8B0029]/30 overflow-hidden" style="left:5%;right:5%;top:4%;bottom:4%;">
        <canvas id="scratch-canvas" class="absolute inset-0 w-full h-full" style="touch-action: none;"></canvas>
        <!-- Top-left: label + page nav -->
        <div class="absolute top-3 left-3 flex items-center gap-2 bg-white/90 backdrop-blur rounded-full px-3 py-1.5 border border-[#8B0029]/30" style="z-index: 2;">
          <span class="w-2 h-2 rounded-full bg-[#8B0029]"></span>
          <span class="text-[#8B0029]/70 text-xs">스크래치</span>
          <div class="w-px h-4 bg-[#8B0029]/20"></div>
          <button id="scratch-prev" class="text-[#8B0029]/40 hover:text-[#8B0029] text-xs px-1">◀</button>
          <span id="scratch-counter" class="text-[#8B0029]/50 text-xs font-mono min-w-[2rem] text-center">1/1</span>
          <button id="scratch-next" class="text-[#8B0029]/40 hover:text-[#8B0029] text-xs px-1">▶</button>
          <button id="scratch-add" class="text-[#8B0029]/40 hover:text-[#8B0029] text-xs px-1" title="새 페이지">+</button>
        </div>
      </div>
    </div>

    <!-- Popup: pen colors / eraser sizes -->
    <div id="tool-popup" class="absolute z-30 hidden" style="bottom: 8px;">
      <div id="tool-popup-inner" class="bg-white/95 backdrop-blur rounded-xl px-3 py-2 shadow-xl border border-[#8B0029]/30">
      </div>
    </div>

    <!-- Thumbnail panel -->
    <div id="thumb-panel" class="absolute inset-0 hidden" style="z-index: 35;">
      <div class="absolute inset-0 bg-black/40" id="thumb-backdrop"></div>
      <div class="absolute bottom-2 left-0 right-0 mx-3">
        <div id="thumb-strip" class="flex gap-2 overflow-x-auto p-3 bg-white/95 backdrop-blur rounded-2xl shadow-2xl border border-[#8B0029]/20">
        </div>
      </div>
    </div>
  </div>

  <!-- Feedback modal -->
  <div id="feedback-modal" class="fixed inset-0 hidden" style="z-index: 100;">
    <div class="absolute inset-0 bg-black/40" id="feedback-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-2xl border border-[#8B0029]/20 w-full max-w-md p-6">
        <h3 class="text-[#8B0029] font-bold text-lg mb-4">강의 피드백</h3>
        <div class="space-y-3">
          <div>
            <label class="text-sm text-gray-600 block mb-1">강의 / 페이지</label>
            <input id="fb-lecture" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029]" />
          </div>
          <div>
            <label class="text-sm text-gray-600 block mb-1">피드백 내용 <span class="text-[#8B0029]">*</span></label>
            <textarea id="fb-content" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029] resize-none"></textarea>
          </div>
          <div>
            <label class="text-sm text-gray-600 block mb-1">이름 (선택)</label>
            <input id="fb-name" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029]" />
          </div>
        </div>
        <div class="flex justify-end gap-2 mt-5">
          <button id="fb-cancel" class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 rounded-lg">취소</button>
          <button id="fb-submit" class="px-4 py-2 text-sm text-white bg-[#8B0029] hover:bg-[#a3003a] rounded-lg font-medium">보내기</button>
        </div>
        <div id="fb-status" class="text-sm mt-2 text-center hidden"></div>
      </div>
    </div>
  </div>

  <!-- Fixed bottom toolbar -->
  <div id="controls" class="flex-shrink-0 bg-white border-t border-[#8B0029]/20" style="touch-action: manipulation;">
    <div class="flex items-center justify-between px-3 py-1">
      <!-- Left: nav + tools -->
      <div class="flex items-center gap-0.5">
        <button id="btn-prev" class="ctrl-btn" title="이전 (←)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button id="slide-counter" class="text-[#8B0029]/50 text-xs font-mono min-w-[3.5rem] text-center hover:text-[#8B0029] cursor-pointer" title="슬라이드 목록"></button>
        <button id="btn-next" class="ctrl-btn" title="다음 (→)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>

        <div class="w-px h-5 bg-[#8B0029]/20 mx-2"></div>

        <!-- PDF download -->
        {pdfUrl && (
          <a href={pdfUrl} download class="ctrl-btn" title="PDF 다운로드">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </a>
        )}

        <div class="w-px h-5 bg-[#8B0029]/20 mx-1"></div>

        <!-- Cursor -->
        <button id="btn-cursor" class="ctrl-btn active" title="클릭 모드 (Q)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="M13 13l6 6"/></svg>
        </button>
        <!-- Pen -->
        <button id="btn-pen" class="ctrl-btn relative" title="펜 (D)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
          <span id="pen-color-dot" class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border border-white" style="background: #ef4444;"></span>
        </button>
        <!-- Eraser -->
        <button id="btn-eraser" class="ctrl-btn" title="지우개 (E)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 20H7L3 16c-.8-.8-.8-2 0-2.8L14.6 1.6c.8-.8 2-.8 2.8 0L21.4 5.6c.8.8.8 2 0 2.8L12 18"/><path d="M6 12l6 6"/></svg>
        </button>
        <!-- Undo -->
        <button id="btn-undo" class="ctrl-btn" title="실행 취소 (⌘/Ctrl+Z)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-15-6.7L3 13"/></svg>
        </button>
        <!-- Redo -->
        <button id="btn-redo" class="ctrl-btn" title="다시 실행 (⌘/Ctrl+Shift+Z)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0115-6.7L21 13"/></svg>
        </button>
        <!-- Clear -->
        <button id="btn-clear" class="ctrl-btn" title="전체 지우기 (C)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M5 6v14a2 2 0 002 2h10a2 2 0 002-2V6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
        </button>

        <div class="w-px h-5 bg-[#8B0029]/20 mx-1"></div>

        <!-- Scratch pad -->
        <button id="btn-scratch" class="ctrl-btn" title="스크래치 패드 (S)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
        </button>
      </div>

      <!-- Right: title -->
      <span class="text-[#8B0029]/30 text-xs hidden sm:block truncate max-w-48">{title}</span>
    </div>
  </div>
</div>

<style>
  .ctrl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    color: rgba(139,0,41,0.5);
    transition: all 0.15s;
  }
  .ctrl-btn:hover {
    color: #8B0029;
    background: rgba(139,0,41,0.1);
  }
  .ctrl-btn.active {
    color: #8B0029;
    background: rgba(139,0,41,0.15);
    box-shadow: inset 0 0 0 1.5px rgba(139,0,41,0.3);
  }
  .ctrl-btn[disabled] {
    color: rgba(139,0,41,0.2);
    cursor: default;
    pointer-events: none;
  }
  #thumb-strip::-webkit-scrollbar {
    height: 6px;
  }
  #thumb-strip::-webkit-scrollbar-thumb {
    background: rgba(139,0,41,0.2);
    border-radius: 3px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- IndexedDB persistence ---
    const DB_NAME = 'slide-drawings';
    const DB_VERSION = 1;
    const STORE_NAME = 'canvases';
    const lectureKey = window.location.pathname;
    let db: IDBDatabase | null = null;

    function openDB(): Promise<IDBDatabase> {
      return new Promise((resolve, reject) => {
        const req = indexedDB.open(DB_NAME, DB_VERSION);
        req.onupgradeneeded = () => {
          req.result.createObjectStore(STORE_NAME);
        };
        req.onsuccess = () => { db = req.result; resolve(db); };
        req.onerror = () => reject(req.error);
      });
    }

    function dbPut(key: string, value: string): void {
      if (!db) return;
      const tx = db.transaction(STORE_NAME, 'readwrite');
      tx.objectStore(STORE_NAME).put(value, key);
    }

    function dbGet(key: string): Promise<string | undefined> {
      return new Promise((resolve) => {
        if (!db) { resolve(undefined); return; }
        const tx = db.transaction(STORE_NAME, 'readonly');
        const req = tx.objectStore(STORE_NAME).get(key);
        req.onsuccess = () => resolve(req.result);
        req.onerror = () => resolve(undefined);
      });
    }

    function dbDelete(key: string): void {
      if (!db) return;
      const tx = db.transaction(STORE_NAME, 'readwrite');
      tx.objectStore(STORE_NAME).delete(key);
    }

    // Debounced persist
    const persistTimers: Map<string, number> = new Map();
    function persistCanvas(key: string, cvs: HTMLCanvasElement) {
      const dataUrl = cvs.toDataURL('image/png'); // capture immediately
      const timerId = persistTimers.get(key);
      if (timerId) clearTimeout(timerId);
      persistTimers.set(key, window.setTimeout(() => {
        dbPut(key, dataUrl);
        persistTimers.delete(key);
      }, 300));
    }

    function drawKey(slideIndex: number) { return `${lectureKey}:slide:${slideIndex}`; }
    function scratchKey(pageIndex: number) { return `${lectureKey}:scratch:${pageIndex}`; }
    function scratchMetaKey() { return `${lectureKey}:scratch:meta`; }

    function loadImageToCanvas(dataUrl: string, cvs: HTMLCanvasElement, context: CanvasRenderingContext2D): Promise<void> {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const dpr = window.devicePixelRatio || 1;
          context.clearRect(0, 0, cvs.width / dpr, cvs.height / dpr);
          context.drawImage(img, 0, 0, cvs.width / dpr, cvs.height / dpr);
          resolve();
        };
        img.onerror = () => resolve();
        img.src = dataUrl;
      });
    }

    const slidesEl = document.querySelectorAll<HTMLDivElement>('.slide');
    const counter = document.getElementById('slide-counter')!;
    const canvas = document.getElementById('draw-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const mainArea = document.getElementById('main-area')!;
    const total = slidesEl.length;
    let current = 0;

    // --- Drawing state ---
    type DrawMode = 'none' | 'pen' | 'eraser';
    let drawMode: DrawMode = 'none';
    let penColor = '#ef4444';
    let eraserSize = 30;
    const drawingData: Map<number, ImageData> = new Map();
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;

    // --- Undo/redo state (in-memory only, per-slide / per-scratch-page) ---
    const MAX_HISTORY = 20;
    const slideHistory: Map<number, ImageData[]> = new Map();
    const slideRedo: Map<number, ImageData[]> = new Map();
    const scratchHistory: Map<number, ImageData[]> = new Map();
    const scratchRedo: Map<number, ImageData[]> = new Map();

    function snapshotCanvas(c: HTMLCanvasElement, cx: CanvasRenderingContext2D): ImageData {
      return cx.getImageData(0, 0, c.width, c.height);
    }

    function pushSnapshot(stack: ImageData[] | undefined, snap: ImageData): ImageData[] {
      const s = stack ?? [];
      s.push(snap);
      while (s.length > MAX_HISTORY) s.shift();
      return s;
    }

    function pushSlideHistorySnapshot() {
      slideHistory.set(current, pushSnapshot(slideHistory.get(current), snapshotCanvas(canvas, ctx)));
      slideRedo.delete(current); // any new edit invalidates redo
      updateUndoButtons();
    }

    function pushScratchHistorySnapshot() {
      scratchHistory.set(scratchCurrentPage, pushSnapshot(scratchHistory.get(scratchCurrentPage), snapshotCanvas(scratchCanvas, scratchCtx)));
      scratchRedo.delete(scratchCurrentPage);
      updateUndoButtons();
    }

    function undoSlide() {
      const hist = slideHistory.get(current);
      if (!hist || hist.length === 0) return;
      const prev = hist.pop()!;
      slideRedo.set(current, pushSnapshot(slideRedo.get(current), snapshotCanvas(canvas, ctx)));
      ctx.putImageData(prev, 0, 0);
      saveDrawing();
      updateUndoButtons();
    }

    function redoSlide() {
      const redo = slideRedo.get(current);
      if (!redo || redo.length === 0) return;
      const next = redo.pop()!;
      slideHistory.set(current, pushSnapshot(slideHistory.get(current), snapshotCanvas(canvas, ctx)));
      ctx.putImageData(next, 0, 0);
      saveDrawing();
      updateUndoButtons();
    }

    function undoScratch() {
      const hist = scratchHistory.get(scratchCurrentPage);
      if (!hist || hist.length === 0) return;
      const prev = hist.pop()!;
      scratchRedo.set(scratchCurrentPage, pushSnapshot(scratchRedo.get(scratchCurrentPage), snapshotCanvas(scratchCanvas, scratchCtx)));
      scratchCtx.putImageData(prev, 0, 0);
      scratchSavePage();
      updateUndoButtons();
    }

    function redoScratch() {
      const redo = scratchRedo.get(scratchCurrentPage);
      if (!redo || redo.length === 0) return;
      const next = redo.pop()!;
      scratchHistory.set(scratchCurrentPage, pushSnapshot(scratchHistory.get(scratchCurrentPage), snapshotCanvas(scratchCanvas, scratchCtx)));
      scratchCtx.putImageData(next, 0, 0);
      scratchSavePage();
      updateUndoButtons();
    }

    function doUndo() { if (scratchOpen) undoScratch(); else undoSlide(); }
    function doRedo() { if (scratchOpen) redoScratch(); else redoSlide(); }

    function updateUndoButtons() {
      const hist = scratchOpen ? scratchHistory.get(scratchCurrentPage) : slideHistory.get(current);
      const redo = scratchOpen ? scratchRedo.get(scratchCurrentPage) : slideRedo.get(current);
      btnUndo.toggleAttribute('disabled', !hist || hist.length === 0);
      btnRedo.toggleAttribute('disabled', !redo || redo.length === 0);
    }

    // --- UI refs ---
    const btnPen = document.getElementById('btn-pen')!;
    const btnEraser = document.getElementById('btn-eraser')!;
    const btnCursor = document.getElementById('btn-cursor')!;
    const btnUndo = document.getElementById('btn-undo')!;
    const btnRedo = document.getElementById('btn-redo')!;
    const penColorDot = document.getElementById('pen-color-dot')!;
    const toolPopup = document.getElementById('tool-popup')!;
    const toolPopupInner = document.getElementById('tool-popup-inner')!;
    const eraserCursor = document.getElementById('eraser-cursor')!;

    // --- Canvas setup ---
    function resizeCanvas() {
      const oldWidth = canvas.width;
      const oldHeight = canvas.height;
      let tempCanvas: HTMLCanvasElement | null = null;
      if (oldWidth > 0 && oldHeight > 0) {
        tempCanvas = document.createElement('canvas');
        tempCanvas.width = oldWidth;
        tempCanvas.height = oldHeight;
        tempCanvas.getContext('2d')!.drawImage(canvas, 0, 0);
      }

      const dpr = window.devicePixelRatio || 1;
      canvas.width = canvas.clientWidth * dpr;
      canvas.height = canvas.clientHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const data = drawingData.get(current);
      if (data && data.width === canvas.width && data.height === canvas.height) {
        ctx.putImageData(data, 0, 0);
      } else if (tempCanvas && oldWidth > 0) {
        ctx.drawImage(tempCanvas, 0, 0, oldWidth, oldHeight, 0, 0, canvas.width / dpr * dpr, canvas.height / dpr * dpr);
        saveDrawing();
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    function saveDrawing() {
      drawingData.set(current, ctx.getImageData(0, 0, canvas.width, canvas.height));
      persistCanvas(drawKey(current), canvas);
    }

    function restoreDrawing() {
      const data = drawingData.get(current);
      if (data && data.width === canvas.width && data.height === canvas.height) {
        ctx.putImageData(data, 0, 0);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        // Try loading from IndexedDB
        dbGet(drawKey(current)).then(async (dataUrl) => {
          if (dataUrl) {
            await loadImageToCanvas(dataUrl, canvas, ctx);
            drawingData.set(current, ctx.getImageData(0, 0, canvas.width, canvas.height));
          }
        });
      }
    }


    // --- Scratch pad ---
    const scratchPad = document.getElementById('scratch-pad')!;
    const scratchCanvas = document.getElementById('scratch-canvas') as HTMLCanvasElement;
    const scratchCtx = scratchCanvas.getContext('2d')!;
    const scratchCounter = document.getElementById('scratch-counter')!;
    let scratchOpen = false;

    const scratchPages: Map<number, ImageData> = new Map();
    let scratchCurrentPage = 0;
    let scratchTotalPages = 1;
    let scratchColor = '#ef4444';

    function resizeScratchCanvas() {
      const dpr = window.devicePixelRatio || 1;
      scratchCanvas.width = scratchCanvas.clientWidth * dpr;
      scratchCanvas.height = scratchCanvas.clientHeight * dpr;
      scratchCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
      scratchRestorePage();
    }

    function scratchSavePage() {
      scratchPages.set(scratchCurrentPage, scratchCtx.getImageData(0, 0, scratchCanvas.width, scratchCanvas.height));
      persistCanvas(scratchKey(scratchCurrentPage), scratchCanvas);
      dbPut(scratchMetaKey(), JSON.stringify({ totalPages: scratchTotalPages }));
    }

    function scratchRestorePage() {
      const data = scratchPages.get(scratchCurrentPage);
      if (data && data.width === scratchCanvas.width && data.height === scratchCanvas.height) {
        scratchCtx.putImageData(data, 0, 0);
      } else {
        scratchCtx.clearRect(0, 0, scratchCanvas.width, scratchCanvas.height);
        dbGet(scratchKey(scratchCurrentPage)).then(async (dataUrl) => {
          if (dataUrl) {
            await loadImageToCanvas(dataUrl, scratchCanvas, scratchCtx);
            scratchPages.set(scratchCurrentPage, scratchCtx.getImageData(0, 0, scratchCanvas.width, scratchCanvas.height));
          }
        });
      }
    }

    function scratchUpdateCounter() {
      scratchCounter.textContent = `${scratchCurrentPage + 1}/${scratchTotalPages}`;
    }

    function scratchGoTo(page: number) {
      if (page < 0 || page >= scratchTotalPages) return;
      scratchSavePage();
      scratchCurrentPage = page;
      scratchRestorePage();
      scratchUpdateCounter();
      updateUndoButtons();
    }

    function toggleScratchPad() {
      scratchOpen = !scratchOpen;
      scratchPad.classList.toggle('hidden', !scratchOpen);
      document.getElementById('btn-scratch')!.classList.toggle('active', scratchOpen);
      if (scratchOpen) {
        resizeScratchCanvas();
        scratchUpdateCounter();
      }
      updateUndoButtons();
    }

    function closeScratchPad() {
      if (scratchOpen) toggleScratchPad();
    }

    // Scratch drawing — uses main drawMode (pen/eraser)
    let scratchDrawing = false;
    let scratchLastX = 0;
    let scratchLastY = 0;

    function scratchGetPos(e: MouseEvent | TouchEvent): [number, number] {
      const rect = scratchCanvas.getBoundingClientRect();
      if ('touches' in e) return [e.touches[0].clientX - rect.left, e.touches[0].clientY - rect.top];
      return [e.clientX - rect.left, e.clientY - rect.top];
    }

    function scratchStart(e: MouseEvent | TouchEvent) {
      if (drawMode === 'none') return;
      if (!isStylusTouch(e)) return;
      scratchDrawing = true;
      onScratchDrawStart();
      [scratchLastX, scratchLastY] = scratchGetPos(e);
      if (drawMode === 'eraser') {
        eraserCursor.classList.remove('hidden');
        updateEraserCursor(e);
      }
      e.preventDefault();
    }

    function scratchMove(e: MouseEvent | TouchEvent) {
      if (!scratchDrawing) return;
      if ('touches' in e && !isStylusTouch(e)) { scratchStop(); return; }
      e.preventDefault();
      const [x, y] = scratchGetPos(e);
      // Update eraser cursor for scratch pad too
      if (drawMode === 'eraser') {
        updateEraserCursor(e);
      }
      const midX = (scratchLastX + x) / 2;
      const midY = (scratchLastY + y) / 2;

      if (drawMode === 'pen') {
        scratchCtx.strokeStyle = scratchColor;
        scratchCtx.lineWidth = 3;
        scratchCtx.globalCompositeOperation = 'source-over';
      } else {
        scratchCtx.strokeStyle = 'rgba(0,0,0,1)';
        scratchCtx.lineWidth = eraserSize;
        scratchCtx.globalCompositeOperation = 'destination-out';
      }
      scratchCtx.lineCap = 'round';
      scratchCtx.lineJoin = 'round';
      scratchCtx.beginPath();
      scratchCtx.moveTo(scratchLastX, scratchLastY);
      scratchCtx.quadraticCurveTo(scratchLastX, scratchLastY, midX, midY);
      scratchCtx.stroke();
      [scratchLastX, scratchLastY] = [midX, midY];
    }

    function scratchStop() {
      if (scratchDrawing) {
        scratchDrawing = false;
        scratchSavePage();
        eraserCursor.classList.add('hidden');
        onDrawEnd();
      }
    }

    scratchCanvas.addEventListener('mousedown', scratchStart);
    scratchCanvas.addEventListener('mousemove', scratchMove);
    scratchCanvas.addEventListener('mouseup', scratchStop);
    scratchCanvas.addEventListener('mouseleave', scratchStop);
    scratchCanvas.addEventListener('touchstart', scratchStart, { passive: false });
    scratchCanvas.addEventListener('touchmove', scratchMove, { passive: false });
    scratchCanvas.addEventListener('touchend', scratchStop);

    // Scratch pad buttons
    document.getElementById('btn-scratch')!.addEventListener('click', toggleScratchPad);
    document.getElementById('scratch-backdrop')!.addEventListener('click', closeScratchPad);
    document.getElementById('scratch-prev')!.addEventListener('click', () => scratchGoTo(scratchCurrentPage - 1));
    document.getElementById('scratch-next')!.addEventListener('click', () => scratchGoTo(scratchCurrentPage + 1));
    document.getElementById('scratch-add')!.addEventListener('click', () => {
      scratchSavePage();
      scratchTotalPages++;
      scratchCurrentPage = scratchTotalPages - 1;
      scratchCtx.clearRect(0, 0, scratchCanvas.width, scratchCanvas.height);
      scratchUpdateCounter();
      updateUndoButtons();
    });

    // --- Slide position persistence ---
    const slidePositionKey = `${lectureKey}:currentSlide`;

    // --- Slide navigation ---
    function goTo(index: number) {
      if (index < 0 || index >= total) return;
      saveDrawing();
      slidesEl[current].style.display = 'none';
      current = index;
      slidesEl[current].style.display = 'flex';
      counter.textContent = `${current + 1} / ${total}`;
      restoreDrawing();
      // Close scratch pad on slide change
      closeScratchPad();
      updateUndoButtons();
      // Persist current slide
      try { sessionStorage.setItem(slidePositionKey, String(current)); } catch {}
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    // --- Tool popup ---
    let popupTarget: 'pen' | 'eraser' | null = null;

    function showPenColors() {
      popupTarget = 'pen';
      const btnRect = btnPen.getBoundingClientRect();
      const areaRect = mainArea.getBoundingClientRect();
      toolPopup.style.left = `${btnRect.left - areaRect.left}px`;
      toolPopup.style.bottom = '8px';
      toolPopup.style.right = 'auto';
      toolPopup.style.top = 'auto';

      toolPopupInner.innerHTML = '';
      const colors = ['#ef4444', '#1a1a1a', '#facc15', '#22d3ee', '#4ade80', '#ffffff'];
      const labels = ['빨강', '검정', '노랑', '시안', '초록', '흰색'];
      const container = document.createElement('div');
      container.className = 'flex gap-1.5';
      colors.forEach((c, i) => {
        const btn = document.createElement('button');
        const borderCls = c === '#1a1a1a' ? 'border-gray-400' : (c === '#ffffff' ? 'border-gray-300' : 'border-transparent');
        btn.className = `w-7 h-7 rounded-full border-2 hover:scale-110 transition-transform ${c === penColor ? 'ring-2 ring-[#8B0029] scale-110' : borderCls}`;
        btn.style.background = c;
        btn.title = labels[i];
        btn.addEventListener('click', () => {
          setPenColor(c);
          // Also sync scratch color
          scratchColor = c;
          toolPopup.classList.add('hidden');
        });
        container.appendChild(btn);
      });
      toolPopupInner.appendChild(container);
      toolPopup.classList.remove('hidden');
    }

    function showEraserSizes() {
      popupTarget = 'eraser';
      const btnRect = btnEraser.getBoundingClientRect();
      const areaRect = mainArea.getBoundingClientRect();
      toolPopup.style.left = `${btnRect.left - areaRect.left - 20}px`;
      toolPopup.style.bottom = '8px';
      toolPopup.style.right = 'auto';
      toolPopup.style.top = 'auto';

      toolPopupInner.innerHTML = '';
      const sizes = [
        { size: 15, label: 'S' },
        { size: 30, label: 'M' },
        { size: 60, label: 'L' },
      ];
      const container = document.createElement('div');
      container.className = 'flex items-center gap-2';
      sizes.forEach((s) => {
        const btn = document.createElement('button');
        btn.className = `flex items-center justify-center rounded-lg hover:bg-[#8B0029]/20 transition-colors ${s.size === eraserSize ? 'bg-[#8B0029]/15 ring-1 ring-[#8B0029]/30' : ''}`;
        btn.style.width = '40px';
        btn.style.height = '40px';
        const dot = document.createElement('div');
        dot.className = 'rounded-full bg-[#8B0029]/30 border border-[#8B0029]/50';
        const displaySize = Math.min(s.size * 0.5, 28);
        dot.style.width = `${displaySize}px`;
        dot.style.height = `${displaySize}px`;
        btn.appendChild(dot);
        btn.title = s.label;
        btn.addEventListener('click', () => {
          setEraserSize(s.size);
          toolPopup.classList.add('hidden');
        });
        container.appendChild(btn);
      });
      toolPopupInner.appendChild(container);
      toolPopup.classList.remove('hidden');
    }

    // --- Drawing mode ---
    function setMode(mode: DrawMode) {
      drawMode = mode;
      canvas.style.pointerEvents = mode === 'none' ? 'none' : 'auto';
      // Scratch pad canvas also follows mode
      scratchCanvas.style.pointerEvents = (mode === 'none') ? 'none' : 'auto';

      if (mode === 'pen') {
        canvas.style.cursor = 'crosshair';
        scratchCanvas.style.cursor = 'crosshair';
      } else if (mode === 'eraser') {
        canvas.style.cursor = 'none';
        scratchCanvas.style.cursor = 'none';
      } else {
        canvas.style.cursor = 'default';
        scratchCanvas.style.cursor = 'default';
      }

      btnCursor.classList.toggle('active', mode === 'none');
      btnPen.classList.toggle('active', mode === 'pen');
      btnEraser.classList.toggle('active', mode === 'eraser');

      eraserCursor.classList.add('hidden'); // only show when actively erasing
      toolPopup.classList.add('hidden');
    }

    function setPenColor(color: string) {
      penColor = color;
      penColorDot.style.background = color;
    }

    function setEraserSize(size: number) {
      eraserSize = size;
      eraserCursor.style.width = `${size}px`;
      eraserCursor.style.height = `${size}px`;
    }

    // --- Drawing ---
    function getPos(e: MouseEvent | TouchEvent): [number, number] {
      const rect = canvas.getBoundingClientRect();
      if ('touches' in e) return [e.touches[0].clientX - rect.left, e.touches[0].clientY - rect.top];
      return [e.clientX - rect.left, e.clientY - rect.top];
    }

    function getClientPos(e: MouseEvent | TouchEvent): [number, number] {
      if ('touches' in e) return [e.touches[0].clientX, e.touches[0].clientY];
      return [e.clientX, e.clientY];
    }

    // Position the eraser cursor relative to main-area (not viewport-fixed) so it
    // tracks the touch correctly under iPad pinch-zoom. position:fixed elements on
    // iOS Safari follow the visual viewport, but raw clientX/clientY are in layout
    // viewport coordinates — the mismatch is what made the cursor look "off" while
    // the actual erase target was correct.
    function updateEraserCursor(e: MouseEvent | TouchEvent) {
      if (drawMode !== 'eraser') return;
      const [cx, cy] = getClientPos(e);
      const rect = mainArea.getBoundingClientRect();
      eraserCursor.style.left = `${cx - rect.left - eraserSize / 2}px`;
      eraserCursor.style.top = `${cy - rect.top - eraserSize / 2}px`;
    }

    // Touch filter: allow single-finger and stylus, reject multi-touch (palm)
    function isStylusTouch(e: MouseEvent | TouchEvent): boolean {
      if ('touches' in e) {
        if (e.touches.length > 1) return false; // reject multi-touch
        return true; // allow single finger or stylus
      }
      return true; // mouse
    }

    function startDraw(e: MouseEvent | TouchEvent) {
      if (drawMode === 'none') return;
      if (!isStylusTouch(e)) return;
      isDrawing = true;
      onDrawStart();
      [lastX, lastY] = getPos(e);
      if (drawMode === 'eraser') {
        eraserCursor.classList.remove('hidden');
        updateEraserCursor(e);
      }
      e.preventDefault();
    }

    function draw(e: MouseEvent | TouchEvent) {
      if (!isDrawing) return;
      if ('touches' in e && !isStylusTouch(e)) { stopDraw(); return; }
      e.preventDefault();
      const [x, y] = getPos(e);
      updateEraserCursor(e);

      const midX = (lastX + x) / 2;
      const midY = (lastY + y) / 2;

      if (drawMode === 'pen') {
        ctx.strokeStyle = penColor;
        ctx.lineWidth = 3;
        ctx.globalCompositeOperation = 'source-over';
      } else if (drawMode === 'eraser') {
        ctx.strokeStyle = 'rgba(0,0,0,1)';
        ctx.lineWidth = eraserSize;
        ctx.globalCompositeOperation = 'destination-out';
      }

      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.beginPath();
      ctx.moveTo(lastX, lastY);
      ctx.quadraticCurveTo(lastX, lastY, midX, midY);
      ctx.stroke();
      [lastX, lastY] = [midX, midY];
    }

    function stopDraw() {
      if (isDrawing) {
        isDrawing = false;
        saveDrawing();
        eraserCursor.classList.add('hidden');
        onDrawEnd();
      }
    }

    // Eraser cursor tracks mouse only while drawing (startDraw/draw handle it)

    // --- Event listeners ---
    document.addEventListener('keydown', (e) => {
      // 피드백 모달이 열려있으면 Escape만 처리하고 나머지 단축키 무시
      if (!fbModal.classList.contains('hidden')) {
        if (e.key === 'Escape') { closeFeedback(); e.preventDefault(); }
        return;
      }
      // Undo / redo (Ctrl/Cmd+Z, Ctrl/Cmd+Shift+Z, Ctrl/Cmd+Y)
      if ((e.metaKey || e.ctrlKey) && (e.key === 'z' || e.key === 'Z')) {
        if (e.shiftKey) doRedo(); else doUndo();
        e.preventDefault();
        return;
      }
      if ((e.metaKey || e.ctrlKey) && (e.key === 'y' || e.key === 'Y')) {
        doRedo();
        e.preventDefault();
        return;
      }
      if (e.key === 'ArrowRight' || e.key === ' ') { next(); e.preventDefault(); }
      else if (e.key === 'ArrowLeft') { prev(); e.preventDefault(); }
else if (e.key === 'd' || e.key === 'D') {
        if (drawMode === 'pen') showPenColors();
        else setMode('pen');
      }
      else if (e.key === 'e' || e.key === 'E') {
        if (drawMode === 'eraser') showEraserSizes();
        else setMode('eraser');
      }
      else if (e.key === 'c' || e.key === 'C') {
        clearActiveCanvas();
      }
      else if (e.key === 's' || e.key === 'S') { toggleScratchPad(); }
      else if (e.key === 'q' || e.key === 'Q') { setMode('none'); }
      else if (e.key === 'Escape') {
        if (scratchOpen) closeScratchPad();
        else setMode('none');
      }
    });

    // Stroke lifecycle hooks (used by undo history)
    function onDrawStart() {
      pushSlideHistorySnapshot();
    }

    function onScratchDrawStart() {
      pushScratchHistorySnapshot();
    }

    function onDrawEnd() {}

    // Mouse
    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDraw);
    canvas.addEventListener('mouseleave', stopDraw);

    // Touch
    canvas.addEventListener('touchstart', startDraw, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', stopDraw);

    // Touch swipe navigation (when in click mode, single finger only)
    let touchStartX = 0;
    let touchIsSingle = false;
    mainArea.addEventListener('touchstart', (e) => {
      if (drawMode !== 'none') return;
      touchIsSingle = (e.touches.length === 1);
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    mainArea.addEventListener('touchmove', (e) => {
      // If more fingers appear during the gesture, cancel swipe
      if (e.touches.length > 1) touchIsSingle = false;
    }, { passive: true });
    mainArea.addEventListener('touchend', (e) => {
      if (drawMode !== 'none' || !touchIsSingle) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 60) {
        if (dx < 0) next(); else prev();
      }
    }, { passive: true });


    // Buttons
    document.getElementById('btn-prev')!.addEventListener('click', prev);
    document.getElementById('btn-next')!.addEventListener('click', next);
    btnCursor.addEventListener('click', () => setMode('none'));

    btnPen.addEventListener('click', () => {
      if (drawMode === 'pen') showPenColors();
      else setMode('pen');
    });
    btnEraser.addEventListener('click', () => {
      if (drawMode === 'eraser') showEraserSizes();
      else setMode('eraser');
    });
    function clearActiveCanvas() {
      if (scratchOpen) {
        pushScratchHistorySnapshot();
        scratchCtx.clearRect(0, 0, scratchCanvas.width, scratchCanvas.height);
        scratchSavePage();
      } else {
        pushSlideHistorySnapshot();
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        saveDrawing();
      }
    }
    document.getElementById('btn-clear')!.addEventListener('click', clearActiveCanvas);
    btnUndo.addEventListener('click', doUndo);
    btnRedo.addEventListener('click', doRedo);
    // Close popup on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!toolPopup.contains(target) && target !== btnPen && !btnPen.contains(target) && target !== btnEraser && !btnEraser.contains(target)) {
        toolPopup.classList.add('hidden');
      }
    });

    window.addEventListener('resize', resizeCanvas);

    // --- Thumbnail panel ---
    const thumbPanel = document.getElementById('thumb-panel')!;
    const thumbStrip = document.getElementById('thumb-strip')!;
    let thumbsOpen = false;

    function buildThumbnails() {
      thumbStrip.innerHTML = '';
      slidesEl.forEach((slide, i) => {
        const thumb = document.createElement('button');
        thumb.className = `thumb-item flex-shrink-0 rounded-lg overflow-hidden border-2 transition-all ${i === current ? 'border-[#8B0029] shadow-md' : 'border-transparent hover:border-[#8B0029]/30'}`;
        thumb.style.width = '140px';
        thumb.style.height = '90px';
        thumb.style.position = 'relative';
        thumb.style.background = '#fff';

        const preview = document.createElement('div');
        preview.style.cssText = 'transform:scale(0.13);transform-origin:top left;width:1080px;height:700px;overflow:hidden;pointer-events:none;position:absolute;top:0;left:0;';
        preview.innerHTML = slide.querySelector('.slide-content')?.innerHTML || '<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:#8B0029;font-size:3rem;">📝</div>';
        thumb.appendChild(preview);

        const num = document.createElement('div');
        num.style.cssText = 'position:absolute;bottom:2px;right:4px;font-size:10px;font-weight:700;color:#8B0029;background:rgba(255,255,255,0.8);padding:0 4px;border-radius:4px;';
        num.textContent = `${i + 1}`;
        thumb.appendChild(num);

        if (i === current) {
          const dot = document.createElement('div');
          dot.style.cssText = 'position:absolute;top:2px;left:4px;width:6px;height:6px;border-radius:50%;background:#8B0029;';
          thumb.appendChild(dot);
        }

        thumb.addEventListener('click', () => { goTo(i); toggleThumbs(); });
        thumbStrip.appendChild(thumb);
      });

      const currentThumb = thumbStrip.children[current] as HTMLElement;
      if (currentThumb) currentThumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }

    function toggleThumbs() {
      thumbsOpen = !thumbsOpen;
      thumbPanel.classList.toggle('hidden', !thumbsOpen);
      if (thumbsOpen) buildThumbnails();
    }

    counter.addEventListener('click', toggleThumbs);
    document.getElementById('thumb-backdrop')!.addEventListener('click', toggleThumbs);

    // Init
    resizeCanvas();
    setEraserSize(30);
    setPenColor('#ef4444');

    // Restore saved slide position
    try {
      const saved = sessionStorage.getItem(slidePositionKey);
      if (saved) {
        const idx = parseInt(saved, 10);
        if (idx >= 0 && idx < total) {
          slidesEl[current].style.display = 'none';
          current = idx;
          slidesEl[current].style.display = 'flex';
        }
      }
    } catch {}
    counter.textContent = `${current + 1} / ${total}`;

    // Restore drawings from IndexedDB
    openDB().then(async () => {
      // Restore current slide drawing
      const data = await dbGet(drawKey(current));
      if (data) await loadImageToCanvas(data, canvas, ctx);
      saveDrawing();

      // Restore scratch pad metadata
      const meta = await dbGet(scratchMetaKey());
      if (meta) {
        try {
          const parsed = JSON.parse(meta);
          scratchTotalPages = parsed.totalPages || 1;
        } catch {}
      }
    }).catch(() => {});

    // --- Feedback ---
    const fbModal = document.getElementById('feedback-modal')!;
    const fbLecture = document.getElementById('fb-lecture') as HTMLInputElement;
    const fbContent = document.getElementById('fb-content') as HTMLTextAreaElement;
    const fbName = document.getElementById('fb-name') as HTMLInputElement;
    const fbStatus = document.getElementById('fb-status')!;

    function openFeedback() {
      // Auto-fill lecture/page from title and current slide
      fbLecture.value = `${document.title} / ${current + 1}페이지`;
      fbContent.value = '';
      fbStatus.classList.add('hidden');
      fbModal.classList.remove('hidden');
      fbContent.focus();
    }

    function closeFeedback() {
      fbModal.classList.add('hidden');
    }

    async function submitFeedback() {
      const content = fbContent.value.trim();
      if (!content) {
        fbStatus.textContent = '피드백 내용을 입력해주세요.';
        fbStatus.className = 'text-sm mt-2 text-center text-[#8B0029]';
        fbStatus.classList.remove('hidden');
        return;
      }
      const btn = document.getElementById('fb-submit') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = '보내는 중...';
      try {
        const res = await fetch('https://vesper.sogang.ac.kr/PHY1001/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            lecture: fbLecture.value,
            page: current + 1,
            content,
            name: fbName.value.trim(),
          }),
        });
        const data = await res.json();
        if (data.ok) {
          fbStatus.textContent = '피드백이 전송되었습니다. 감사합니다!';
          fbStatus.className = 'text-sm mt-2 text-center text-green-600';
          fbStatus.classList.remove('hidden');
          setTimeout(closeFeedback, 1500);
        } else {
          throw new Error('전송 실패');
        }
      } catch {
        fbStatus.textContent = '전송에 실패했습니다. 다시 시도해주세요.';
        fbStatus.className = 'text-sm mt-2 text-center text-[#8B0029]';
        fbStatus.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = '보내기';
      }
    }

    document.getElementById('btn-feedback')!.addEventListener('click', openFeedback);
    document.getElementById('feedback-backdrop')!.addEventListener('click', closeFeedback);
    document.getElementById('fb-cancel')!.addEventListener('click', closeFeedback);
    document.getElementById('fb-submit')!.addEventListener('click', submitFeedback);

    // KaTeX is now rendered server-side in [id].astro
  });
</script>
