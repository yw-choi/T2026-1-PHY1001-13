---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '서강대학교 일반물리 I (PHY1001) 강의 사이트' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | 일반물리 I</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4VEF9JDEXP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-4VEF9JDEXP');
    </script>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <nav class="bg-[var(--sogang-red)] text-white shadow-lg">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center">
        <a href={`${base}`} class="text-lg font-bold hover:opacity-90">
          일반물리 I
        </a>
        <span class="ml-3 text-sm opacity-70">PHY1001-13 · 2026-1</span>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="mt-16 py-6 bg-[#f9f2f4] text-center text-sm text-[var(--sogang-red)]/60">
      <p>서강대학교 물리학과 · 일반물리 I (PHY1001-13) · 2026년 1학기</p>
      <p class="mt-1"><a href="https://yw-choi.github.io" class="hover:underline">최영우</a></p>
    </footer>

    <!-- Floating feedback button -->
    <button id="btn-feedback" class="fixed top-4 right-4 flex items-center justify-center w-10 h-10 rounded-full bg-white/90 backdrop-blur border border-[#8B0029]/20 text-[#8B0029]/40 hover:text-[#8B0029] hover:bg-white hover:border-[#8B0029]/40 shadow-md transition-all" style="z-index: 90;" title="피드백 보내기">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    </button>

    <!-- Feedback modal -->
    <div id="feedback-modal" class="fixed inset-0 hidden" style="z-index: 100;">
      <div class="absolute inset-0 bg-black/40" id="feedback-backdrop"></div>
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl border border-[#8B0029]/20 w-full max-w-md p-6">
          <h3 class="text-[#8B0029] font-bold text-lg mb-4">강의 피드백</h3>
          <div class="space-y-3">
            <div>
              <label class="text-sm text-gray-600 block mb-1">주제</label>
              <input id="fb-topic" type="text" placeholder="예: 3장 강의, 시뮬레이션 오류, 일반 건의 등" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029]" />
            </div>
            <div>
              <label class="text-sm text-gray-600 block mb-1">내용 <span class="text-[#8B0029]">*</span></label>
              <textarea id="fb-content" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029] resize-none" placeholder="자유롭게 작성해주세요"></textarea>
            </div>
            <div>
              <label class="text-sm text-gray-600 block mb-1">이름 (선택)</label>
              <input id="fb-name" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-[#8B0029]" />
            </div>
          </div>
          <div class="flex justify-end gap-2 mt-5">
            <button id="fb-cancel" class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 rounded-lg">취소</button>
            <button id="fb-submit" class="px-4 py-2 text-sm text-white bg-[#8B0029] hover:bg-[#a3003a] rounded-lg font-medium">보내기</button>
          </div>
          <div id="fb-status" class="text-sm mt-2 text-center hidden"></div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var modal = document.getElementById('feedback-modal');
        var topic = document.getElementById('fb-topic');
        var content = document.getElementById('fb-content');
        var status = document.getElementById('fb-status');

        document.getElementById('btn-feedback').addEventListener('click', function() {
          topic.value = document.title.replace(' | 일반물리 I', '');
          content.value = '';
          status.classList.add('hidden');
          modal.classList.remove('hidden');
          content.focus();
        });
        document.getElementById('feedback-backdrop').addEventListener('click', close);
        document.getElementById('fb-cancel').addEventListener('click', close);
        function close() { modal.classList.add('hidden'); }

        document.getElementById('fb-submit').addEventListener('click', async function() {
          var text = content.value.trim();
          if (!text) {
            status.textContent = '내용을 입력해주세요.';
            status.className = 'text-sm mt-2 text-center text-[#8B0029]';
            status.classList.remove('hidden');
            return;
          }
          this.disabled = true; this.textContent = '보내는 중...';
          try {
            var res = await fetch('https://vesper.sogang.ac.kr/PHY1001/api/feedback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ lecture: topic.value || '(미입력)', content: text, name: document.getElementById('fb-name').value.trim() }),
            });
            var data = await res.json();
            if (data.ok) {
              status.textContent = '피드백이 전송되었습니다. 감사합니다!';
              status.className = 'text-sm mt-2 text-center text-green-600';
              status.classList.remove('hidden');
              setTimeout(close, 1500);
            } else { throw 0; }
          } catch(e) {
            status.textContent = '전송에 실패했습니다. 다시 시도해주세요.';
            status.className = 'text-sm mt-2 text-center text-[#8B0029]';
            status.classList.remove('hidden');
          } finally {
            this.disabled = false; this.textContent = '보내기';
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
