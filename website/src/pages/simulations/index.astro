---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { simulations, simulationGroups, legacySimulations } from '../../data/simulations';
import katex from 'katex';

const base = import.meta.env.BASE_URL;

function renderMath(text: string): string {
  return text.replace(/\$([^$]+)\$/g, (_, expr) =>
    katex.renderToString(expr, { throwOnError: false })
  );
}

const groups = simulationGroups
  .map((g) => ({ label: g.label, sims: simulations.filter(g.filter) }))
  .filter((g) => g.sims.length > 0);

// Group legacy simulations by category
const legacyCategories = [...new Set(legacySimulations.map((s) => s.category))];
const legacyGroups = legacyCategories.map((cat) => ({
  label: cat,
  sims: legacySimulations.filter((s) => s.category === cat),
}));
---

<BaseLayout title="시뮬레이션">
  <section class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold mb-2 text-[var(--sogang-red)]">물리 시뮬레이션</h1>
    <p class="text-gray-500 mb-8">파라미터를 조절하며 물리 현상을 직접 탐구해 보세요.</p>

    {groups.map((group) => (
      <div class="mb-10">
        <h2 class="text-xl font-bold mb-4 text-[var(--sogang-red)]">{group.label}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {group.sims.map((sim) => (
            <a
              href={`${base}simulations/${sim.id}/`}
              class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-4 hover:shadow-md hover:border-[#8B0029]/30 transition-all block"
            >
              <div class="text-xs text-[var(--sogang-red)] mb-1">{sim.chapter}장</div>
              <h3 class="font-bold text-base">{sim.title}</h3>
              <p class="text-sm text-gray-500 mt-1" set:html={renderMath(sim.description)} />
            </a>
          ))}
        </div>
      </div>
    ))}

    <!-- 레거시 시뮬레이션 -->
    <hr class="my-10 border-gray-200" />
    <div>
      <h2 class="text-2xl font-bold mb-2 text-gray-500">이전 시뮬레이션</h2>
      <p class="text-sm text-gray-400 mb-6">일반물리 I·II 전 범위의 시뮬레이션입니다.</p>

      {legacyGroups.map((group) => (
        <div class="mb-8">
          <h3 class="text-lg font-bold mb-3 text-gray-500">{group.label}</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {group.sims.map((sim) => (
              <a
                href={`${base}simulations/legacy/${sim.file}`}
                target="_blank"
                class="bg-gray-50 rounded-lg border border-gray-200 p-3 hover:shadow-sm hover:border-[#8B0029]/30 transition-all block"
              >
                <h4 class="font-medium text-sm">{sim.title}</h4>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
