---
import SlideLayout from '../../../layouts/SlideLayout.astro';
import SlideEngine from '../../../components/SlideEngine.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import katex from 'katex';

export async function getStaticPaths() {
  const lectures = await getCollection('lectures');
  return lectures.map((lecture) => ({
    params: { id: lecture.id },
    props: { lecture },
  }));
}

const { lecture } = Astro.props;
const base = import.meta.env.BASE_URL;

// Split raw markdown by --- slide separators
// We need the raw body, not rendered HTML
const rawContent = lecture.body || '';

// Split on lines that are just "---" (slide separators)
const slideTexts = rawContent
  .split(/\n---\n/)
  .map((s: string) => s.trim())
  .filter((s: string) => s.length > 0);

// Render each slide's markdown to HTML
const slides = await Promise.all(
  slideTexts.map(async (md: string) => {
    // Check for special directives
    const blankMatch = md.match(/<!--\s*blank\s*-->/);
    if (blankMatch) {
      const content = md.replace(/<!--\s*blank\s*-->/, '').trim();
      if (!content) {
        return `<div class="flex items-center justify-center h-full w-full">
          <p class="text-gray-300 text-2xl font-semibold">판서</p>
        </div>`;
      }
      // Render markdown content for the blank page (shown at top)
      const mathBlocks: { tex: string; display: boolean }[] = [];
      const esc = content
        .replace(/\$\$([\s\S]*?)\$\$/g, (_, tex) => { mathBlocks.push({ tex, display: true }); return `%%MATH${mathBlocks.length - 1}%%`; })
        .replace(/\$([^\$\n]+?)\$/g, (_, tex) => { mathBlocks.push({ tex, display: false }); return `%%MATH${mathBlocks.length - 1}%%`; });
      let rendered = String(await marked.parse(esc));
      rendered = rendered.replace(/%%MATH(\d+)%%/g, (_, i) => {
        const { tex, display } = mathBlocks[parseInt(i)];
        try { return katex.renderToString(tex.trim(), { displayMode: display, throwOnError: false }); }
        catch { return tex; }
      });
      return `<div class="w-full h-full flex flex-col" data-blank="true">
        <div class="slide-content px-4 pt-2 pb-1 border-b border-gray-200" style="font-size:0.95rem">${rendered}</div>
      </div>`;
    }

    const simMatch = md.match(/<!--\s*sim:\s*(\S+)\s*-->/);
    if (simMatch) {
      const file = simMatch[1];
      const caption = md.replace(/<!--\s*sim:\s*\S+\s*-->/, '').trim();
      return `<div class="w-full h-full flex flex-col items-center">
        ${caption ? `<h2 class="text-xl font-bold mb-2 text-[#93c5fd]">${caption}</h2>` : ''}
        <iframe src="${base}simulations/${file}" class="w-full flex-1 rounded-lg border border-white/10" style="min-height:70vh"></iframe>
      </div>`;
    }

    // Protect LaTeX math from markdown parsing:
    // Replace $...$ and $$...$$ with placeholders before marked processes them
    const mathBlocks: { tex: string; display: boolean }[] = [];
    const escaped = md
      .replace(/\$\$([\s\S]*?)\$\$/g, (_, tex) => {
        mathBlocks.push({ tex, display: true });
        return `%%MATH${mathBlocks.length - 1}%%`;
      })
      .replace(/\$([^\$\n]+?)\$/g, (_, tex) => {
        mathBlocks.push({ tex, display: false });
        return `%%MATH${mathBlocks.length - 1}%%`;
      });

    let html = String(await marked.parse(escaped));

    // Render math server-side with KaTeX (avoids innerHTML < escaping issues)
    html = html.replace(/%%MATH(\d+)%%/g, (_, i) => {
      const { tex, display } = mathBlocks[parseInt(i)];
      try {
        return katex.renderToString(tex.trim(), { displayMode: display, throwOnError: false });
      } catch {
        return tex;
      }
    });

    // Prepend base URL to absolute image paths
    return html.replace(/src="\/img\//g, `src="${base}img/`);
  })
);
---

<SlideLayout title={lecture.data.title}>
  <SlideEngine title={lecture.data.title} slides={slides} pdfUrl={`${base}pdf/${lecture.id}.pdf`} />
</SlideLayout>
