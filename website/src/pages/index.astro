---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { simulations, legacySimulations } from '../data/simulations';
import katex from 'katex';

const base = import.meta.env.BASE_URL;

function renderMath(text: string): string {
  return text.replace(/\$([^$]+)\$/g, (_, expr) =>
    katex.renderToString(expr, { throwOnError: false })
  );
}

// --- Chapter titles (Halliday) ---
const chapterTitles: Record<number, string> = {
  1: '측정',
  2: '직선 운동',
  3: '벡터',
  4: '2차원·3차원 운동',
  5: '힘과 운동 I',
  6: '힘과 운동 II',
  7: '운동에너지와 일',
  8: '퍼텐셜에너지와 보존',
  9: '질량중심과 선운동량',
  10: '회전',
  11: '구름·돌림힘·각운동량',
  12: '평형과 탄성',
  13: '중력',
  14: '유체',
  15: '진동',
  16: '파동 I',
  17: '파동 II',
  18: '온도, 열, 열역학 제1법칙',
  19: '기체 분자 운동론',
  20: '엔트로피와 열역학 제2법칙',
};

// --- Lecture data ---
// Slide lectures from content collection
const allSlideLectures = await getCollection('lectures');
const slideLecByChapter = new Map<number, { id: string }[]>();
for (const lec of allSlideLectures) {
  const match = lec.data.title.match(/^(\d+)장/);
  if (match) {
    const ch = parseInt(match[1]);
    if (!slideLecByChapter.has(ch)) slideLecByChapter.set(ch, []);
    slideLecByChapter.get(ch)!.push({ id: lec.id });
  }
}

// --- Homework chapters (1-10) ---
const hwChapters = new Set(Array.from({ length: 20 }, (_, i) => i + 1));

// --- Simulations by chapter ---
const simsByChapter = new Map<number, typeof simulations>();
for (const sim of simulations) {
  if (!simsByChapter.has(sim.chapter)) simsByChapter.set(sim.chapter, []);
  simsByChapter.get(sim.chapter)!.push(sim);
}

// --- Build chapter cards ---
const maxCh = 20;
const chapters = Array.from({ length: maxCh }, (_, i) => {
  const ch = i + 1;
  return {
    ch,
    title: chapterTitles[ch] || '',
    slides: slideLecByChapter.get(ch) || [],
    sims: simsByChapter.get(ch) || [],
    hasHomework: hwChapters.has(ch),
  };
});

// --- Legacy simulations ---
const legacyCategories = [...new Set(legacySimulations.map((s) => s.category))];
const legacyGroups = legacyCategories.map((cat) => ({
  label: cat,
  sims: legacySimulations.filter((s) => s.category === cat),
}));
---

<BaseLayout title="홈">
  <!-- Hero -->
  <section class="bg-[var(--sogang-red)] text-white py-14">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-2">서강대학교 일반물리 I</h1>
      <p class="text-xl opacity-90">PHY1001-13 · 2026년 1학기</p>
    </div>
  </section>

  <!-- Info -->
  <section class="max-w-4xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-6">
        <h2 class="text-lg font-bold mb-4 text-[var(--sogang-red)]">강의 정보</h2>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-[#8B0029]/10">
              <td class="py-2 font-medium w-24 text-[var(--sogang-red)]">담당</td>
              <td><a href="https://yw-choi.github.io" class="hover:text-[var(--sogang-red)] hover:underline">최영우</a></td>
            </tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">시간</td><td>수, 금 15:00-16:15</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">장소</td><td>K304</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">면담</td><td>월,화,목 10:00-12:00 (이메일 예약)</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">이메일</td><td>ywchoi02@sogang.ac.kr</td></tr>
            <tr><td class="py-2 font-medium text-[var(--sogang-red)]">홈페이지</td><td><a href="https://yw-choi.github.io" target="_blank" class="text-[var(--sogang-red)] hover:underline">yw-choi.github.io</a></td></tr>
          </tbody>
        </table>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-6">
        <h2 class="text-lg font-bold mb-4 text-[var(--sogang-red)]">교재 & 평가</h2>
        <div class="text-sm space-y-4">
          <div>
            <p class="font-medium text-[var(--sogang-red)] mb-1">교재</p>
            <p class="font-semibold">Principles of Physics, 12/E</p>
            <p class="text-gray-500">Resnick, Halliday, Walker</p>
          </div>
          <div>
            <p class="font-medium text-[var(--sogang-red)] mb-2">평가</p>
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-[#8B0029]/5 rounded-lg p-3 text-center">
                <p class="text-2xl font-bold text-[var(--sogang-red)]">50%</p>
                <p class="text-xs text-gray-500 mt-1">중간고사</p>
              </div>
              <div class="bg-[#8B0029]/5 rounded-lg p-3 text-center">
                <p class="text-2xl font-bold text-[var(--sogang-red)]">50%</p>
                <p class="text-xs text-gray-500 mt-1">기말고사</p>
              </div>
            </div>
          </div>
          <div>
            <a
              href={`${base}syllabus/extended%20syllabus_%EC%9D%BC%EB%B0%98%EB%AC%BC%EB%A6%ACI.pdf`}
              target="_blank"
              class="inline-flex items-center gap-2 text-[var(--sogang-red)] hover:underline font-medium"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              강의계획서 다운로드
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 강의 자료 -->
  <section class="max-w-4xl mx-auto px-4 pb-14">
    <h2 class="text-2xl font-bold text-[var(--sogang-red)] mb-5">강의 자료</h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <!-- 소개 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#8B0029]/25 transition-all">
        <div class="border-l-4 border-gray-300 px-4 py-4">
          <p class="text-sm font-bold text-gray-600 mb-3">소개</p>
          <div class="flex flex-wrap gap-2">
            <a href={`${base}slides/intro.pdf`} target="_blank"
              class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-[#8B0029]/8 text-[#8B0029] hover:bg-[#8B0029]/18 transition-colors">
              강의자료
            </a>
          </div>
        </div>
      </div>

      <!-- 챕터 카드 -->
      {chapters.map(({ ch, title, slides, hasHomework }) => (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#8B0029]/25 transition-all">
          <div class="border-l-4 border-[#8B0029] px-4 py-4">
            <p class="text-sm font-bold mb-3">
              <span class="text-[#8B0029] text-base font-extrabold mr-1.5">{ch}장</span>
              <span class="text-gray-800">{title}</span>
            </p>
            <div class="flex flex-wrap gap-2">
              {slides.map((sl) => (
                <a href={`${base}lectures/${sl.id}/`}
                  class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-[#8B0029]/8 text-[#8B0029] hover:bg-[#8B0029]/18 transition-colors">
                  강의자료
                </a>
                <a href={`${base}pdf/${sl.id}.pdf`} download
                  class="inline-flex items-center gap-1 text-xs font-semibold px-3 py-1 rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  PDF
                </a>
              ))}
              {hasHomework && (
                <>
                  <a href={`${base}homeworks/ch${String(ch).padStart(2, '0')}_homework.pdf`} target="_blank"
                    class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                    숙제
                  </a>
                  <a href={`${base}homeworks/ch${String(ch).padStart(2, '0')}_homework_solution.pdf`} target="_blank"
                    class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 hover:bg-emerald-100 transition-colors">
                    솔루션
                  </a>
                </>
              )}
            </div>
          </div>
        </div>
      ))}

      <!-- AI 코딩 (맨 마지막) -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#8B0029]/25 transition-all">
        <div class="border-l-4 border-gray-300 px-4 py-4">
          <p class="text-sm font-bold text-gray-600 mb-3">AI 코딩</p>
          <div class="flex flex-wrap gap-2">
            <a href={`${base}slides/ai-coding.pdf`} target="_blank"
              class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-[#8B0029]/8 text-[#8B0029] hover:bg-[#8B0029]/18 transition-colors">
              강의자료
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 시뮬레이션 -->
  <section class="max-w-4xl mx-auto px-4 pb-14">
    <h2 class="text-2xl font-bold text-[var(--sogang-red)] mb-5">시뮬레이션</h2>

    {Array.from(simsByChapter.entries()).sort((a, b) => a[0] - b[0]).map(([ch, chSims]) => (
      <div class="mb-6">
        <h3 class="text-sm font-bold text-[#8B0029] mb-3">{ch}장 · {chapterTitles[ch]}</h3>
        <div class="grid sm:grid-cols-2 gap-3">
          {chSims.map((sim) => (
            <a href={`${base}simulations/${sim.id}/`}
              class="group block bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md hover:border-[#8B0029]/25 transition-all">
              <div class="border-l-4 border-[#8B0029] px-5 py-3">
                <h3 class="text-sm font-bold mb-1 group-hover:text-[#8B0029] transition-colors">{sim.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed" set:html={renderMath(sim.description)} />
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- 이전 시뮬레이션 -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <h2 class="text-xl font-bold text-gray-400 mb-4">이전 시뮬레이션</h2>
    <p class="text-sm text-gray-400 mb-6">일반물리 I·II 전 범위의 시뮬레이션입니다.</p>

    {legacyGroups.map((group) => (
      <div class="mb-5">
        <h3 class="text-sm font-bold mb-2 text-gray-400">{group.label}</h3>
        <div class="flex flex-wrap gap-2">
          {group.sims.map((sim) => (
            <a
              href={`${base}simulations/legacy/${sim.file}`}
              target="_blank"
              class="text-sm px-3 py-1.5 rounded-lg bg-gray-50 border border-gray-200 text-gray-600 hover:border-[#8B0029]/30 hover:text-[var(--sogang-red)] transition-colors"
            >
              {sim.title}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
